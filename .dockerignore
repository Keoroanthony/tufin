# .dockerignore controls what is sent to the Docker daemon as the build context.
# Excluding large or irrelevant directories:
#   - speeds up `docker build` (less data transferred to daemon)
#   - prevents build/IDE artefacts from accidentally invalidating cache layers
#   - ensures local build output never overwrites the in-container build

# Git internals — never needed inside an image
.git
.gitattributes
.gitignore

# Gradle local cache and wrapper download cache — large, not needed in image;
# the builder stage re-downloads dependencies inside the container.
.gradle/

# IntelliJ project files
.idea/
*.iml
*.iws
*.ipr
out/

# Local build output — must be excluded so that a local `./gradlew build`
# does not pollute or conflict with the Docker build.
build/

# Application logs generated by the startup script
logs/

# Windows Gradle wrapper — not needed on Linux containers
gradlew.bat

# Docker files themselves
Dockerfile
.dockerignore

# Documentation — not needed at runtime
*.md
